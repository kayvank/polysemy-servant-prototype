packages: ./src/www
packages: ./src/structured-logger
          -- TODO this project is deprecated and needs to be removed
-- packages: ./src/logger

-- Required for Polysemy's type-level magic
package polysemy
  flags: +use-template-haskell

-- GHC plugin for Polysemy (removes the need for manual type annotations)
package myapp
  ghc-options: -fplugin=Polysemy.Plugin
